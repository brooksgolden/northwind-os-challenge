# AI "draft a reply" provider. Copy to .env to override defaults.
#
# DRAFT_PROVIDER selects how replies are generated:
#   cli      (default) -> uses the local Claude Code CLI, i.e. your Claude subscription (no API cost)
#   api                -> uses the Anthropic API (set ANTHROPIC_API_KEY below)
#   template           -> deterministic offline draft, no model needed
#
# Any provider falls back to the template on failure, so the app always works.

# DRAFT_PROVIDER=cli

# Only needed when DRAFT_PROVIDER=api (the production path):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5
